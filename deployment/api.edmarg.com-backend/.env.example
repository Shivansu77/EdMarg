# EdMarg backend production env for api.edmarg.com
# Copy this file to .env before starting the app.

# Server
PORT=3000
NODE_ENV=production
LOG_LEVEL=info

# Database
MONGODB_URI=mongodb+srv://USERNAME:PASSWORD@CLUSTER.mongodb.net/edmarg_db?retryWrites=true&w=majority
DB_NAME=edmarg_db

# JWT
JWT_SECRET=replace-with-a-long-random-secret-minimum-32-characters
JWT_EXPIRES_IN=7d

# Frontend origins allowed to call this API
FRONTEND_ORIGIN=https://www.edmarg.com
FRONTEND_ORIGINS=https://edmarg.com,https://www.edmarg.com
NEXT_PUBLIC_APP_URL=https://www.edmarg.com

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://api.edmarg.com/api/v1/users/auth/google/callback

# Cloudinary
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Email / SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM="EdMarg <noreply@edmarg.com>"

# Zoom
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=
ZOOM_WEBHOOK_SECRET=

# Optional Mongo tuning
MONGODB_MAX_POOL_SIZE=20
MONGODB_MIN_POOL_SIZE=2
MONGODB_SERVER_SELECTION_TIMEOUT_MS=8000
MONGODB_CONNECT_TIMEOUT_MS=10000
