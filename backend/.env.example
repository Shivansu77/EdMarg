# Server Configuration
PORT=5000
NODE_ENV=development

# Database Configuration
MONGODB_URI=mongodb://127.0.0.1:27017/edmarg_db
DB_NAME=edmarg_db

# JWT Configuration
JWT_SECRET=replace-with-a-long-random-secret-minimum-32-characters
JWT_EXPIRES_IN=7d

# Frontend Configuration
FRONTEND_ORIGIN=http://localhost:3000

# Logging
LOG_LEVEL=debug

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=5

# Zoom Integration
ZOOM_ACCOUNT_ID=your_zoom_account_id
ZOOM_CLIENT_ID=your_zoom_client_id
ZOOM_CLIENT_SECRET=your_zoom_client_secret
ZOOM_WEBHOOK_SECRET=your_zoom_webhook_secret_for_challenge

# Cloudinary (used for profile images + session recordings)
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# Email Service (Nodemailer SMTP)
# For Gmail: use smtp.gmail.com with an App Password (https://myaccount.google.com/apppasswords)
# For production: use SendGrid (smtp.sendgrid.net), Mailgun, or AWS SES
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=gripgrap9@gmail.com
SMTP_PASS=zxtq mmvc wvtl rhkh
EMAIL_FROM="EdMarg <gripgrap9@gmail.com>"
