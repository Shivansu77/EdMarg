{
  "compilerOptions": {
    "target": "es2022",
    "module": "commonjs",
    "moduleDetection": "force",
    "rootDir": "./",
    "outDir": "./dist",
    "types": [
      "node"
    ],
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": false,
    "noImplicitAny": false,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": [
    "**/*.ts"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}
