{
  "info": {
    "name": "EdMarg Assessment System",
    "description": "Complete API collection for the assessment system",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:5000/api/v1/assessments"
    },
    {
      "key": "adminToken",
      "value": "your_admin_token_here"
    },
    {
      "key": "studentToken",
      "value": "your_student_token_here"
    },
    {
      "key": "templateId",
      "value": ""
    },
    {
      "key": "assignmentId",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Templates",
      "item": [
        {
          "name": "Create Template",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Student Interest & Skills Assessment\",\n  \"description\": \"Understand student interests, skills, and goals\",\n  \"questions\": [\n    {\n      \"id\": \"interests\",\n      \"type\": \"checkbox\",\n      \"question\": \"What are your primary areas of interest?\",\n      \"options\": [\"Science\", \"Technology\", \"Engineering\", \"Mathematics\", \"Arts\", \"Business\"],\n      \"required\": true\n    },\n    {\n      \"id\": \"experience\",\n      \"type\": \"multipleChoice\",\n      \"question\": \"What is your current experience level?\",\n      \"options\": [\"Beginner\", \"Intermediate\", \"Advanced\", \"Expert\"],\n      \"required\": true\n    },\n    {\n      \"id\": \"goals\",\n      \"type\": \"text\",\n      \"question\": \"What are your learning goals?\",\n      \"required\": true\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/templates",
              "host": ["{{baseUrl}}"],
              "path": ["templates"]
            }
          }
        },
        {
          "name": "Get All Templates",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/templates",
              "host": ["{{baseUrl}}"],
              "path": ["templates"]
            }
          }
        },
        {
          "name": "Get Template by ID",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/templates/{{templateId}}",
              "host": ["{{baseUrl}}"],
              "path": ["templates", "{{templateId}}"]
            }
          }
        },
        {
          "name": "Update Template",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Updated Assessment Title\",\n  \"description\": \"Updated description\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/templates/{{templateId}}",
              "host": ["{{baseUrl}}"],
              "path": ["templates", "{{templateId}}"]
            }
          }
        },
        {
          "name": "Delete Template",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/templates/{{templateId}}",
              "host": ["{{baseUrl}}"],
              "path": ["templates", "{{templateId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Assignments",
      "item": [
        {
          "name": "Create Assignment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"templateId\": \"{{templateId}}\",\n  \"studentIds\": [\"student_id_1\", \"student_id_2\"],\n  \"dueDate\": \"2024-12-31T23:59:59Z\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/assignments",
              "host": ["{{baseUrl}}"],
              "path": ["assignments"]
            }
          }
        },
        {
          "name": "Get All Assignments (Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/assignments",
              "host": ["{{baseUrl}}"],
              "path": ["assignments"]
            }
          }
        },
        {
          "name": "Get My Assignments (Student)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{studentToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/assignments/my",
              "host": ["{{baseUrl}}"],
              "path": ["assignments", "my"]
            }
          }
        },
        {
          "name": "Update Assignment",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"dueDate\": \"2024-12-31T23:59:59Z\",\n  \"isActive\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/assignments/{{assignmentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["assignments", "{{assignmentId}}"]
            }
          }
        },
        {
          "name": "Delete Assignment",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/assignments/{{assignmentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["assignments", "{{assignmentId}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Responses",
      "item": [
        {
          "name": "Save Progress (Draft)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{studentToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"answers\": {\n    \"interests\": [\"Technology\", \"Science\"],\n    \"experience\": \"Intermediate\"\n  },\n  \"submit\": false\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/responses/{{assignmentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["responses", "{{assignmentId}}"]
            }
          }
        },
        {
          "name": "Submit Assessment",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{studentToken}}"
              },
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"answers\": {\n    \"interests\": [\"Technology\", \"Science\"],\n    \"experience\": \"Intermediate\",\n    \"goals\": \"Learn programming and build projects\"\n  },\n  \"submit\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/responses/{{assignmentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["responses", "{{assignmentId}}"]
            }
          }
        },
        {
          "name": "Get My Response",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{studentToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/responses/my/{{assignmentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["responses", "my", "{{assignmentId}}"]
            }
          }
        },
        {
          "name": "Get Assignment Responses (Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/responses/assignment/{{assignmentId}}",
              "host": ["{{baseUrl}}"],
              "path": ["responses", "assignment", "{{assignmentId}}"]
            }
          }
        },
        {
          "name": "Get All Responses (Admin)",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{adminToken}}"
              }
            ],
            "url": {
              "raw": "{{baseUrl}}/responses",
              "host": ["{{baseUrl}}"],
              "path": ["responses"]
            }
          }
        }
      ]
    }
  ]
}
