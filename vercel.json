{
  "version": 2,
  "functions": {
    "api/*.js": {
      "includeFiles": "backend/**"
    }
  },
  "rewrites": [
    {
      "source": "/api/hello",
      "destination": "/api/hello.js"
    },
    {
      "source": "/api/diag",
      "destination": "/api/diag.js"
    },
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/status",
      "destination": "/api/index.js"
    }
  ]
}
